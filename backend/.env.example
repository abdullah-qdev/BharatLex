MONGODB_URI=mongodb+srv://bharatlex_user:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=bharatlex

# Add later when we wire AI calls.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_NUM_PREDICT=320
OLLAMA_TEMPERATURE=0.2
OLLAMA_DISABLE_THINKING=true
FINAL_SYNTHESIS_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional fallback if you switch FINAL_SYNTHESIS_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
RAG_TOP_K=6
RAG_MIN_SCORE=0.2
DEBATE_ROUNDS=2

# Optional on Windows if tesseract.exe is not on PATH.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# Optional if language data is stored outside the Tesseract install.
# TESSDATA_DIR=C:\Users\abdul\BharatLex\backend\ocr\tessdata

# Optional speech-to-text for /api/speech/ask.
SARVAM_API_KEY=
SARVAM_STT_MODEL=saaras:v3
SARVAM_LANGUAGE_CODE=unknown
